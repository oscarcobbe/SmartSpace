# Resend (https://resend.com) — required for /api/contact
RESEND_API_KEY=re_xxxxxxxx
# Must be an address Resend allows: onboarding@resend.dev for tests, or your verified domain
RESEND_FROM_EMAIL="Smart Space <onboarding@resend.dev>"
# Where contact form emails are delivered (defaults to info@smart-space.ie if unset)
CONTACT_TO_EMAIL=info@smart-space.ie
