# ─────────────────────────────────────────────────────────────────────
# Smart Space — environment variables
#
# Local: copy to .env.local and fill in real values. .env.local is
# gitignored. Production: set the same keys in Vercel project settings.
# ─────────────────────────────────────────────────────────────────────

# ── Email (Resend, https://resend.com) — required for every form ──
RESEND_API_KEY=re_xxxxxxxx
# Verified-domain sender preferred. Sandbox `onboarding@resend.dev`
# works for testing only — DKIM-unverifiable, deliverability hits.
RESEND_FROM_EMAIL="Smart Space <noreply@smart-space.ie>"
# Where lead notification emails are delivered (defaults to info@smart-space.ie)
CONTACT_TO_EMAIL=info@smart-space.ie

# ── Stripe (https://stripe.com) — required for /api/checkout + webhook ──
# Live mode key (sk_live_...). Test mode key (sk_test_...) for staging.
STRIPE_SECRET_KEY=sk_live_xxxxxxxx
# Webhook signing secret. Get from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# ── Calendly (https://calendly.com) — required for booking calendar ──
CALENDLY_PERSONAL_TOKEN=your_calendly_personal_token
CALENDLY_CONSULTATION_EVENT_TYPE_URI=https://api.calendly.com/event_types/your_consultation_event_type_id
CALENDLY_INSTALLATION_EVENT_TYPE_URI=https://api.calendly.com/event_types/your_installation_event_type_id

# ── Google Sheet leads webhook (Apps Script) ──
# The deployed Apps Script web-app URL. See google-apps-script.js for setup.
GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/.../exec
# Token gating reads from the Sheet (must match Apps Script's READ_TOKEN
# Script Property — see google-apps-script.js for rotation steps).
GOOGLE_SHEET_READ_TOKEN=long_random_hex_from_openssl_rand_hex_32

# ── GA4 server-side conversions ──
# https://analytics.google.com/analytics → Admin → Data Streams →
# Measurement Protocol API secrets
GA4_API_SECRET=mp_xxxxxxxx
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google Ads conversion labels ──
# Pulled into both client + server fires. If a conversion action is
# recreated in Google Ads, paste the new full `AW-NNNN/<label>` here
# and redeploy. The diagnostic page at /admin/conversion-test shows
# which label is currently in use.
NEXT_PUBLIC_GADS_LEAD_SEND_TO=AW-17978501655/u8cHCNyipZocEJfU6PxC
NEXT_PUBLIC_GADS_PAYMENT_SEND_TO=AW-17978501655/IofPCOiZuJkcEJfU6PxC
NEXT_PUBLIC_GADS_FREE_CONSULT_SEND_TO=AW-17978501655/fH4ZCMHv7ZocEJfU6PxC
# Phone-call conversion (label only, prefix is added in code)
NEXT_PUBLIC_GADS_CALL_LABEL=your_phone_call_conversion_label

# ── Admin auth ──
# Long random string. Gates /api/admin/leads (admin dashboard).
# Generate: openssl rand -hex 32
ADMIN_KEY=long_random_hex_from_openssl_rand_hex_32

# ── Vercel cron auth ──
# Sent as Bearer header by Vercel cron. If unset, BOTH crons return 401
# silently (no monitoring). Generate: openssl rand -hex 32
CRON_SECRET=long_random_hex_from_openssl_rand_hex_32

# ── Twilio SMS (optional) — for high-value-order alerts ──
# All four required if any are set. Without these, sendSms is a no-op.
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+353xxxxxxxxx
TWILIO_TO_NUMBER=+353xxxxxxxxx

# ── SmartCRM mirror (optional, currently dormant) — see src/lib/crm.ts ──
# Both required if any are set. Without these, sendToCrm is a no-op.
CRM_INBOUND_URL=https://crm.smart-space.ie/api/inbound/lead
CRM_HMAC_SECRET=long_random_hex_from_openssl_rand_hex_32
