# Resend (https://resend.com) — required for /api/contact
RESEND_API_KEY=re_xxxxxxxx
# Must be an address Resend allows: onboarding@resend.dev for tests, or your verified domain
RESEND_FROM_EMAIL="Smart Space <onboarding@resend.dev>"
# Where contact form emails are delivered (defaults to info@smart-space.ie if unset)
CONTACT_TO_EMAIL=info@smart-space.ie

# Calendly (https://calendly.com) — required for booking calendar
CALENDLY_PERSONAL_TOKEN=your_calendly_personal_token
CALENDLY_CONSULTATION_EVENT_TYPE_URI=https://api.calendly.com/event_types/your_consultation_event_type_id
CALENDLY_INSTALLATION_EVENT_TYPE_URI=https://api.calendly.com/event_types/your_installation_event_type_id
